PORT=8001
# Set to "production" on your live server (see README) — this file is also
# used for local development, where NODE_ENV should stay unset.
# NODE_ENV=production

# Path to the SQLite database file (created automatically on first boot).
DB_PATH=./data/fynbeauty.sqlite

# REQUIRED in production: a random string of at least 32 characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_DAYS=7

# Comma-separated list of allowed origins — set this to your real domain(s)
# before going live, e.g. https://votre-domaine.com. Do not leave as "*" in
# production.
CORS_ORIGINS=*

ADMIN_EMAIL=admin@fynbeauty.store
# CHANGE THIS — the value below is published in the project README.
ADMIN_PASSWORD=adminoussamafyn2026
